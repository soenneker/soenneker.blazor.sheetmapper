@page "/"
@using Soenneker.Blazor.SheetMapper.Demo.Dtos

<Div Space="Space.Y.Is6">
    <DemoPanel Title="Sheet mapper" Description="Map CSV rows to a C# model. Icons show mapping state.">
        <SheetMapper TargetType="typeof(Employee)"
                     @ref="_sheetMapper"
                     AutomaticallyMap="true">
            <NotMappedIcon>
                <Span TextColor="TextColor.MutedForeground" title="Not mapped">!</Span>
            </NotMappedIcon>

            <DuplicatedIcon>
                <Span Class="text-red-600 dark:text-red-400" title="Duplicated">!</Span>
            </DuplicatedIcon>

            <MappedIcon>
                <Span TextColor="TextColor.Primary" title="Mapped">OK</Span>
            </MappedIcon>
        </SheetMapper>

        <Button OnClick="AutoMap">AutoMap</Button>
    </DemoPanel>
</Div>

@code {
    private SheetMapper _sheetMapper = null!;

    private void AutoMap() => _sheetMapper.AutoMap();
}
